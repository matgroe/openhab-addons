<?xml version="1.0" encoding="UTF-8"?>
<thing:thing-descriptions bindingId="giraone"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:thing="https://openhab.org/schemas/thing-description/v1.0.0"
	xsi:schemaLocation="https://openhab.org/schemas/thing-description/v1.0.0 https://openhab.org/schemas/thing-description-1.0.0.xsd">

	<!--
		All Non-Known Devices are getting mapped to the unkown thing
		https://www.openhab.org/docs/developer/bindings/thing-xml.html#state-channel-types
	-->

	<thing-type id="shutter-venetian-blind">
		<supported-bridge-type-refs>
			<bridge-type-ref id="server"/>
		</supported-bridge-type-refs>
		<label>Shutter</label>
		<description>Venetianblind Roller- or Covering Shutter </description>
		<category>Blinds</category>

		<channels>
			<channel id="events" typeId="sendEvent"/>
			<channel id="step-up-down" typeId="shutter-step-up-down"/>
			<channel id="up-down" typeId="shutter-up-down"/>
			<channel id="internal-movement-state" typeId="shutter-movement"/>
			<channel id="position" typeId="shutter-position"/>
			<channel id="slat-position" typeId="shutter-slat-position"/>
		</channels>

		<properties>
			<property name="channelViewUrn">Unique ChannelView URN</property>
			<property name="functionType">Channel Function Type</property>
			<property name="channelType">Channel Type</property>
			<property name="channelTypeId">Channel Type ID</property>
		</properties>
		<representation-property>channelViewUrn</representation-property>

	</thing-type>

	<channel-type id="shutter-position">
		<item-type>Rollershutter</item-type>
		<label>Position</label>
		<description>Raise/lower the blind level</description>
		<category>Rollershutter</category>
		<tags>
			<tag>Setpoint</tag>
			<tag>Level</tag>
		</tags>
		<state min="0" step="5" max="100" pattern="%.0f %%"/>
	</channel-type>

	<channel-type id="shutter-slat-position">
		<item-type>Number:Dimensionless</item-type>
		<label>Shutter Slat Position</label>
		<description>Change Venetian Blind Slat Position</description>
		<category>Rollershutter</category>
		<tags>
			<tag>Setpoint</tag>
			<tag>Level</tag>
		</tags>
		<state min="0" step="5" max="100" pattern="%.0f %%"/>
	</channel-type>

	<channel-type id="shutter-movement">
		<item-type>String</item-type>
		<label>Shutter Moving State</label>
		<description>Gives informationa </description>
		<category>Motion</category>
		<state readOnly="true">
			<options>
				<option value="STOPPED">Stopped</option>
				<option value="UP">Up</option>
				<option value="DOWN">Down</option>
			</options>
		</state>
		<autoUpdatePolicy>veto</autoUpdatePolicy>
	</channel-type>

	<channel-type id="shutter-up-down">
		<item-type>Rollershutter</item-type>
		<label>Move Up/Down</label>
		<description>Raise/lower the blind level to position</description>
		<category>Rollershutter</category>
		<state/>
	</channel-type>

	<channel-type id="shutter-step-up-down">
		<item-type>Rollershutter</item-type>
		<label>Step Up/Down</label>
		<description>Raise/lower the blind level by single step</description>
		<category>Rollershutter</category>
		<state/>
	</channel-type>

	<channel-type id="sendEvent">
		<item-type>String</item-type>
		<label>Send Event</label>
		<description>A stateless channel for sending sensor events.</description>
		<state>
			<options>
				<option value="EVENT_1">Event 1</option>
				<option value="EVENT_2">Event 2</option>
				<option value="EVENT_3">Event 3</option>
			</options>
		</state>
	</channel-type>
</thing:thing-descriptions>
