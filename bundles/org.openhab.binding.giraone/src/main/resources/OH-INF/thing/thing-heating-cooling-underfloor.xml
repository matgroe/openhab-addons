<?xml version="1.0" encoding="UTF-8"?>
<thing:thing-descriptions bindingId="giraone"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:thing="https://openhab.org/schemas/thing-description/v1.0.0"
	xsi:schemaLocation="https://openhab.org/schemas/thing-description/v1.0.0 https://openhab.org/schemas/thing-description-1.0.0.xsd">

	<!--
		All Non-Known Devices are getting mapped to the unkown thing
		https://www.openhab.org/docs/developer/bindings/thing-xml.html#state-channel-types
	-->
	<thing-type id="heating-cooling-underfloor">
		<supported-bridge-type-refs>
			<bridge-type-ref id="server"/>
		</supported-bridge-type-refs>

		<label>Heating/Cooling</label>
		<description>Underfloor Heating or Cooling</description>

		<channels>
			<channel id="current" typeId="current-temperature"/>
			<channel id="set-point" typeId="set-point-temperature"/>
			<channel id="mode" typeId="mode-temperature"/>
			<!-- channel id="status" typeId="system.indoor-temperature" -->
			<!-- channel id="heating" typeId="system.atmospheric-humidity" -->
		</channels>
	</thing-type>

	<channel-type id="current-temperature">
		<category>TemperatureHot</category>
		<item-type>Number:Dimensionless</item-type>
		<label>Current Temperature</label>
		<tags>
			<tag>Measurement</tag>
			<tag>Temperature</tag>
		</tags>
		<state readOnly="true" pattern="%.1f °C"/>
	</channel-type>

	<channel-type id="set-point-temperature">
		<category>Temperature</category>
		<item-type>Number</item-type>
		<label>Setpoint Temperature</label>
		<tags>
			<tag>Setpoint</tag>
			<tag>Level</tag>
			<tag>Temperature</tag>
		</tags>
		<state min="10" max="30" step="0.5" pattern="%.1f °C" readOnly="false"/>
	</channel-type>


	<channel-type id="mode-temperature">
		<item-type>String</item-type>
		<label>Heater Mode</label>
		<description>Heater Mode</description>
		<category>Heating</category>
		<state readOnly="false">
			<options>
				<option value="1">Komfort</option>
				<option value="2">Standby</option>
				<option value="3">Nacht</option>
				<option value="4">Frostschutz</option>
			</options>
		</state>
		<autoUpdatePolicy>veto</autoUpdatePolicy>
	</channel-type>

</thing:thing-descriptions>
